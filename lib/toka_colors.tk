import std/string::String
pub fn red()     -> String { return String::from("\x1b[31m") }
pub fn green()   -> String { return String::from("\x1b[32m") }
pub fn yellow()  -> String { return String::from("\x1b[33m") }
pub fn blue()    -> String { return String::from("\x1b[34m") }
pub fn cyan()    -> String { return String::from("\x1b[36m") }
pub fn bold()    -> String { return String::from("\x1b[1m") }
pub fn dim()     -> String { return String::from("\x1b[2m") }
pub fn reset()   -> String { return String::from("\x1b[0m") }
