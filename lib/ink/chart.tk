// toka-chart v0.2.0 — 柱状图
// v0.9.2 优化：str.repeat() + String::fmt() 替代手动循环 + digit()/int_str()
import std/string::String

pub fn bar(label: String, pct: i32) -> String {
    auto w = 16
    auto fill = pct * w / 100
    auto rest = w - fill
    auto llen = label.len() as i32
    auto pad# = 6 - llen
    if pad < 0 { pad = 0 }
    
    auto result# = String::fmt("\x1b[36m{}{} ", label, cede s" ".repeat(pad))
    
    // 颜色 + 填充块
    if pct >= 80 { result#.push_str("\x1b[32m") }
    else if pct >= 50 { result#.push_str("\x1b[33m") }
    else { result#.push_str("\x1b[31m") }
    result#.push_str(cede s"\xe2\x96\x88".repeat(fill).c_str())
    
    // 空块
    result#.push_str("\x1b[90m")
    result#.push_str(cede s"\xe2\x96\x91".repeat(rest).c_str())
    
    // 百分比（3字符右对齐）
    result#.push_str("\x1b[0m  ")
    auto pct_s = String::fmt("{}", pct)
    if pct < 100 { result#.push_str(" ") }
    if pct < 10 { result#.push_str(" ") }
    result#.push_str(pct_s.c_str())
    result#.push_str("%")
    
    return cede result
}
