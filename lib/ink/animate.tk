// toka_animate v0.2.0 — 终端文字动画
// v0.9.2 优化：String::fmt() + str.repeat() 替代手动循环和 from_int
import std/io::stdout
import std/string::String
import std/task::sleep

// ── Typewriter ──────────────────────────────────────────
pub fn typewrite(text: String, speed_ms: i32) {
    auto out = stdout()
    auto len = text.len() as i32
    auto i# = 0
    while i <= len {
        auto chunk# = String::from(text.substring(0, i as u64))
        out.write("\r")
        out.write(chunk.c_str())
        out.write(cede s" ".repeat(len - i).c_str())
        out.flush()
        sleep(speed_ms)
        i = i + 1
    }
    out.write("\n")
}

// ── Blink ───────────────────────────────────────────────
pub fn blink(text: String, times: i32, speed_ms: i32) {
    auto out = stdout()
    auto len = text.len() as i32
    auto i# = 0
    while i < times {
        out.write("\r\x1b[1;31m")
        out.write(text.c_str())
        out.write("\x1b[0m")
        out.flush()
        sleep(speed_ms)
        out.write("\r")
        out.write(cede s" ".repeat(len).c_str())
        out.write("\r")
        out.flush()
        sleep(speed_ms / 2)
        i = i + 1
    }
    out.write("\r\x1b[1;31m")
    out.write(text.c_str())
    out.write("\x1b[0m\n")
}

// ── Bounce ──────────────────────────────────────────────
pub fn bounce(text: String, cycles: i32, speed_ms: i32) {
    auto out = stdout()
    auto frames# = String::from("-\\|/")
    auto total = 4
    auto i# = 0
    while i < cycles * total {
        auto idx = i % total
        auto ch# = String::from("")
        unsafe {
            auto *fbuf = frames.c_str() as *[char]
            ch#.push_char(fbuf[idx])
        }
        out.write("\r\x1b[36m")
        out.write(ch.c_str())
        out.write("\x1b[0m ")
        out.write(text.c_str())
        out.write("  ")
        out.flush()
        sleep(speed_ms)
        i = i + 1
    }
    out.write("\r\x1b[32m\xe2\x9c\x93\x1b[0m ")
    out.write(text.c_str())
    out.write("\n")
}

// ── Pulse Bar ───────────────────────────────────────────
pub fn pulse_bar(duration_ms: i32, steps: i32) {
    auto out = stdout()
    auto delay# = duration_ms / steps
    auto i# = 0
    while i <= steps {
        auto pct = (i * 100) / steps
        auto filled = (i * 20) / steps
        auto remain = 20 - filled

        out.write("\r\x1b[34m[\x1b[0m")

        auto j# = 0
        while j < filled {
            if j == filled - 1 && i < steps {
                out.write("\x1b[1;37m#\x1b[0m")
            } else {
                out.write("\x1b[34m#\x1b[0m")
            }
            j = j + 1
        }

        out.write(cede s"\x1b[90m-\x1b[0m".repeat(remain).c_str())
        out.write("\x1b[34m]\x1b[0m ")

        auto pct_str = String::fmt("{}", pct)
        if pct < 100 { out.write(" ") }
        if pct < 10 { out.write(" ") }
        out.write(pct_str.c_str())
        out.write("%")
        out.flush()

        sleep(delay)
        i = i + 1
    }
    out.write("\n")
}
